// -*- mode: jsonc -*-
{
    "mpris": {
        "format": "{player_icon} {title} - {artist}",
        "format-paused": "{status_icon} <i>{title} - {artist}</i>",
        "player-icons": {
            "default": "▶",
            "mpv": "🎵",
        },
        "status-icons": {
            "paused": "⏸",
        },
        "ignored-players": ["brave", "firefox"],
    },
}
