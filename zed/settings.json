{
    "prettier": {
        "allowed": true
    },
    "show_whitespaces": "selection",
    "indent_guides": {
        "background_coloring": "disabled",
        "coloring": "fixed",
        "active_line_width": 0,
        "line_width": 1,
    },
    "soft_wrap": "editor_width",
    "toolbar": {
        "selections_menu": true,
        "quick_actions": false,
        "breadcrumbs": true,
    },
    "scrollbar": {
        "axes": {
            "horizontal": true,
            "vertical": true,
        },
        "show": "auto",
    },
    "gutter": {
        "folds": true,
        "breakpoints": true,
        "runnables": true,
    },
    "relative_line_numbers": "disabled",
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    "ui_font_weight": 400.0,
    "zoomed_padding": true,
    "preview_tabs": {
        "enable_preview_file_from_code_navigation": false,
        "enable_preview_from_multibuffer": false,
        "enable_preview_from_project_panel": false,
        "enable_preview_multibuffer_from_code_navigation": false,
        "enable_preview_from_file_finder": false,
        "enabled": false,
    },
    "search": {
        "button": false,
    },
    "terminal": {
        "dock": "bottom",
        "scrollbar": {
            "show": "never",
        },
        "font_size": 12.0,
    },
    "collaboration_panel": {
        "button": false,
    },
    "notification_panel": {
        "button": false,
    },
    "debugger": {
        "button": false,
        "dock": "left",
    },
    "git_panel": {
        "scrollbar": {
            "show": "never",
        },
        "tree_view": true,
        "default_width": 300.0,
        "status_style": "icon",
        "dock": "left",
    },
    "outline_panel": {
        "indent_size": 16.0,
        "file_icons": true,
        "dock": "right",
        "button": false,
    },
    "tab_size": 4,
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
            },
            "enable_lsp_tasks": true,
        },
    },
    "project_panel": {
        "button": true,
        "hide_root": true,
        "indent_guides": {
            "show": "never",
        },
        "scrollbar": {
            "show": "never",
        },
        "bold_folder_labels": false,
        "auto_reveal_entries": false,
        "file_icons": true,
        "indent_size": 16.0,
        "folder_icons": false,
        "entry_spacing": "standard",
        "default_width": 240.0,
        "dock": "left",
    },
    "edit_predictions": {
        "provider": "none",
    },
    "show_completion_documentation": false,
    "inlay_hints": {
        "show_value_hints": false,
    },
    "inline_code_actions": true,
    "active_pane_modifiers": {
        "inactive_opacity": 0.0,
        "border_size": 0.0,
    },
    "max_tabs": 1,
    "use_system_window_tabs": false,
    "agent": {
        "default_profile": "ask",
        "dock": "left",
        "tool_permissions": {
            "tools": {
                "fetch": {
                    "default": "allow",
                },
                "terminal": {
                    "default": "allow",
                },
            },
        },
        "default_model": {
            "enable_thinking": false,
            "provider": "copilot_chat",
            "model": "gpt-5.3-codex",
        },
        "favorite_models": [],
        "model_parameters": [],
    },
    "window_decorations": "server",
    "status_bar": {
        "active_encoding_button": "enabled",
        "active_language_button": true,
        "cursor_position_button": true,
    },
    "diagnostics": {
        "button": false,
    },
    "tabs": {
        "show_close_button": "hidden",
        "file_icons": false,
        "git_status": false,
    },
    "tab_bar": {
        "show_nav_history_buttons": false,
        "show_tab_bar_buttons": false,
        "show": false,
    },
    "title_bar": {
        "show_menus": false,
        "show_user_picture": false,
        "show_user_menu": true,
        "show_sign_in": true,
        "show_onboarding_banner": false,
        "show_project_items": true,
        "show_branch_name": true,
        "show_branch_icon": true,
    },
    "cursor_shape": "block",
    "text_rendering_mode": "subpixel",
    "agent_ui_font_size": 12.0,
    "ui_font_family": "GeistMono Nerd Font Propo",
    "buffer_font_family": "GeistMono Nerd Font Mono",
    "icon_theme": {
        "mode": "system",
        "light": "Material Icon Theme",
        "dark": "Base Charmed Icons",
    },
    "ui_font_size": 14.0,
    "buffer_font_size": 12.0,
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "Vercel Dark",
    },
    "theme_overrides": {
        "One Dark": {
            "border": "#111111FF",
            "border.variant": "#111111FF",
            "border.focused": "#111111FF",
            "border.selected": "#111111FF",
            "border.disabled": "#111111FF",
            "elevated_surface.background": "#111111FF",
            "surface.background": "#111111FF",
            "background": "#111111FF",
            "element.background": "#111111FF",
            "text": "#FCFCFCFF",
            "text.muted": "#656565FF",
            "text.placeholder": "#555555FF",
            "text.disabled": "#555555FF",
            "icon": "#FCFCFCFF",
            "icon.muted": "#656565FF",
            "icon.disabled": "#555555FF",
            "status_bar.background": "#111111FF",
            "title_bar.background": "#111111FF",
            "title_bar.inactive_background": "#111111FF",
            "toolbar.background": "#111111FF",
            "tab_bar.background": "#111111FF",
            "tab.inactive_background": "#111111FF",
            "tab.active_background": "#111111FF",
            "panel.background": "#111111FF",
            "panel.focused_border": "#111111FF",
            "pane.focused_border": "#111111FF",
            "scrollbar.thumb.background": "#222222FF",
            "scrollbar.thumb.hover_background": "#333333FF",
            "scrollbar.thumb.border": "#11111100",
            "scrollbar.track.border": "#11111100",
            "editor.foreground": "#FCFCFCFF",
            "editor.background": "#111111FF",
            "editor.gutter.background": "#111111FF",
            "editor.subheader.background": "#111111FF",
            "editor.active_line.background": "#222222FF",
            "editor.highlighted_line.background": "#111111FF",
            "editor.line_number": "#656565FF",
            "editor.active_line_number": "#FFFFFFFF",
            "editor.hover_line_number": "#666666FF",
            "terminal.background": "#111111FF",
            "terminal.foreground": "#FCFCFCFF",
            "terminal.bright_foreground": "#FCFCFCFF",
            "hidden": "#333333FF",
            "hidden.background": "#2222221A",
            "hidden.border": "#444444FF",
            "ignored": "#333333FF",
            "ignored.background": "#2222221A",
            "players": [
                {
                    "cursor": "#74ade8ff",
                    "background": "#74ade8ff",
                    "selection": "#be50463d",
                },
                {
                    "cursor": "#bf956aff",
                    "background": "#bf956aff",
                    "selection": "#bf956a3d",
                },
                {
                    "cursor": "#b477cfff",
                    "background": "#b477cfff",
                    "selection": "#b477cf3d",
                },
                {
                    "cursor": "#6eb4bfff",
                    "background": "#6eb4bfff",
                    "selection": "#6eb4bf3d",
                },
                {
                    "cursor": "#d07277ff",
                    "background": "#d07277ff",
                    "selection": "#d072773d",
                },
                {
                    "cursor": "#dec184ff",
                    "background": "#dec184ff",
                    "selection": "#dec1843d",
                },
                {
                    "cursor": "#a1c181ff",
                    "background": "#a1c181ff",
                    "selection": "#a1c1813d",
                },
            ],
            "panel.overlay_background": "#111111FF",
            "panel.overlay_hover": "#111111FF",
            "minimap.thumb.background": "#222222FF",
            "minimap.thumb.hover_background": "#333333FF",
            "minimap.thumb.border": "#11111100",
            "version_control.ignored": "#333333FF",
        },
    },
    "languages": {
        "Rust": {
            "format_on_save": "on",
            "formatter": "language_server",
        },
    },
}
